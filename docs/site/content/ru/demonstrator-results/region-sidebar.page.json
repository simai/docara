{
  "schema": "docara.page.v1",
  "title": "Sidebar с дополнительным блоком",
  "description": "Навигационный Smart-компонент и безопасный текстовый блок.",
  "layout": {
    "regions": {
      "sidebar": {
        "enabled": true,
        "sections": [
          {"id": "docs-navigation", "section": "docara.navigation"},
          {
            "id": "sidebar-note",
            "section": "docara.shell",
            "utilities": ["flex", "flex-col", "gap-1", "p-2", "surface-0"],
            "blocks": [
              {
                "id": "hint",
                "block": "shell.element",
                "slot": "content",
                "element": {"tag": "p", "text": "Нужен быстрый старт? Начните с установки.", "utilities": ["m-0"]}
              },
              {
                "id": "install-link",
                "block": "shell.element",
                "slot": "content",
                "element": {"tag": "a", "text": "Открыть установку", "href": "/start/", "aria_label": "Открыть руководство по установке"}
              }
            ]
          }
        ]
      }
    }
  }
}
