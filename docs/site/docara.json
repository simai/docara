{
  "schema": "docara.site.v1",
  "title": "Docara",
  "preset": "docs",
  "content_root": "content",
  "framework_lock": "simai-framework.lock.json",
  "default_locale": "ru",
  "base_url": "/",
  "branding": {
    "title": "Docara",
    "label": "Документация",
    "logo": "assets/docara-mark.svg",
    "logo_dark": "assets/docara-mark.svg",
    "favicon": "assets/docara-mark.svg"
  },
  "layout": {
    "max_width": "wide"
  },
  "settings": {
    "theme": "system"
  },
  "search": {
    "enabled": true,
    "indexed": true
  },
  "reading": {
    "breadcrumbs": true,
    "toc": true,
    "toc_depth": 3,
    "previous_next": true
  }
}
