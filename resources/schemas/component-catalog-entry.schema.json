{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/component-catalog-entry/v1",
    "title": "Docara effective component catalogue entry",
    "type": "object",
    "required": [
        "id",
        "family",
        "category",
        "title",
        "description",
        "presentation",
        "lifecycle",
        "authoring",
        "states",
        "limitations",
        "verification",
        "docs_ref",
        "provenance"
    ],
    "properties": {
        "id": {
            "$ref": "#/$defs/id"
        },
        "family": {
            "$ref": "#/$defs/family"
        },
        "category": {
            "$ref": "#/$defs/non_empty_string"
        },
        "title": {
            "$ref": "#/$defs/non_empty_string"
        },
        "description": {
            "$ref": "#/$defs/non_empty_string"
        },
        "presentation": {
            "$ref": "#/$defs/presentation"
        },
        "lifecycle": {
            "$ref": "#/$defs/lifecycle"
        },
        "authoring": {
            "$ref": "#/$defs/authoring"
        },
        "states": {
            "$ref": "#/$defs/string_list"
        },
        "limitations": {
            "$ref": "#/$defs/string_list"
        },
        "verification": {
            "$ref": "#/$defs/verification"
        },
        "docs_ref": {
            "$ref": "#/$defs/safe_path"
        },
        "example_ref": {
            "$ref": "#/$defs/safe_path"
        },
        "provenance": {
            "$ref": "#/$defs/provenance"
        },
        "consumer_policy": {
            "$ref": "#/$defs/consumer_policy"
        },
        "gap": {
            "$ref": "#/$defs/gap"
        }
    },
    "additionalProperties": false,
    "$defs": {
        "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
        },
        "family": {
            "type": "string",
            "enum": [
                "native_markdown",
                "docara_typed",
                "framework_smart",
                "requirement"
            ]
        },
        "lifecycle": {
            "type": "string",
            "enum": [
                "supported",
                "admission_pending",
                "framework_gap",
                "deferred"
            ]
        },
        "non_empty_string": {
            "type": "string",
            "minLength": 1
        },
        "presentation": {
            "type": "object",
            "required": ["ru"],
            "properties": {
                "ru": {
                    "$ref": "#/$defs/localized_presentation"
                }
            },
            "additionalProperties": false
        },
        "localized_presentation": {
            "type": "object",
            "required": ["title", "description", "limitations", "states", "parameters"],
            "properties": {
                "title": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "description": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "limitations": {
                    "$ref": "#/$defs/string_list"
                },
                "states": {
                    "$ref": "#/$defs/localized_labels"
                },
                "parameters": {
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^[a-z][a-z0-9_-]*$"
                    },
                    "additionalProperties": {
                        "$ref": "#/$defs/localized_parameter"
                    }
                },
                "example_ref": {
                    "$ref": "#/$defs/safe_path"
                },
                "gap": {
                    "$ref": "#/$defs/localized_gap"
                }
            },
            "additionalProperties": false
        },
        "localized_labels": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/$defs/non_empty_string"
            }
        },
        "localized_parameter": {
            "type": "object",
            "required": ["label", "description"],
            "properties": {
                "label": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "description": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "values": {
                    "$ref": "#/$defs/localized_labels"
                }
            },
            "additionalProperties": false
        },
        "localized_gap": {
            "type": "object",
            "required": ["reason", "fallback", "admission_condition"],
            "properties": {
                "reason": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "fallback": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "admission_condition": {
                    "$ref": "#/$defs/non_empty_string"
                }
            },
            "additionalProperties": false
        },
        "safe_path": {
            "type": "string",
            "format": "docara-relative-path"
        },
        "string_list": {
            "type": "array",
            "uniqueItems": true,
            "items": {
                "$ref": "#/$defs/non_empty_string"
            }
        },
        "authoring": {
            "type": "object",
            "required": ["syntax", "call", "jobs", "parameters"],
            "properties": {
                "syntax": {
                    "type": "string",
                    "enum": [
                        "markdown",
                        "directive",
                        "directive_json",
                        "proposed_directive",
                        "unavailable"
                    ]
                },
                "call": {
                    "type": ["string", "null"],
                    "minLength": 1
                },
                "jobs": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_]*$"
                    }
                },
                "parameters": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/parameter"
                    }
                },
                "constraints": {
                    "$ref": "#/$defs/constraints"
                }
            },
            "additionalProperties": false
        },
        "parameter": {
            "type": "object",
            "required": ["name", "type", "required", "description"],
            "properties": {
                "name": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_-]*$"
                },
                "type": {
                    "type": "string",
                    "enum": ["string", "boolean", "integer", "number", "enum", "markdown"]
                },
                "required": {
                    "type": "boolean"
                },
                "description": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "values": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/scalar"
                    }
                },
                "default": {
                    "$ref": "#/$defs/scalar"
                },
                "validation": {
                    "$ref": "#/$defs/parameter_validation"
                },
                "mirrors": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_-]*$"
                    }
                }
            },
            "additionalProperties": false
        },
        "parameter_validation": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "min_length": {
                    "type": "integer",
                    "minimum": 0
                },
                "max_length": {
                    "type": "integer",
                    "minimum": 0
                },
                "pattern": {
                    "type": "string",
                    "minLength": 1
                },
                "minimum": {
                    "type": "number"
                },
                "maximum": {
                    "type": "number"
                }
            },
            "additionalProperties": false
        },
        "constraints": {
            "type": "object",
            "required": ["allowed_combinations", "requires"],
            "properties": {
                "allowed_combinations": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["keys", "values"],
                        "properties": {
                            "keys": {
                                "type": "array",
                                "minItems": 1,
                                "uniqueItems": true,
                                "items": {
                                    "type": "string",
                                    "pattern": "^[a-z][a-z0-9_-]*$"
                                }
                            },
                            "values": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": {
                                        "$ref": "#/$defs/scalar"
                                    }
                                }
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "requires": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["when", "then"],
                        "properties": {
                            "when": {
                                "$ref": "#/$defs/condition"
                            },
                            "then": {
                                "$ref": "#/$defs/condition"
                            }
                        },
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        },
        "condition": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
                "$ref": "#/$defs/scalar"
            }
        },
        "scalar": {
            "type": ["string", "boolean", "integer", "number"]
        },
        "verification": {
            "type": "object",
            "required": ["renderer", "tests", "docs", "demo"],
            "properties": {
                "renderer": {
                    "type": "boolean"
                },
                "tests": {
                    "type": "boolean"
                },
                "docs": {
                    "type": "boolean"
                },
                "demo": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "provenance": {
            "type": "object",
            "required": ["source_kind"],
            "properties": {
                "source_kind": {
                    "type": "string",
                    "enum": [
                        "portable_markdown_profile",
                        "typed_definition",
                        "smart_consumer_metadata",
                        "product_requirement"
                    ]
                },
                "profile_id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9._-]+$"
                },
                "definition_ref": {
                    "$ref": "#/$defs/safe_path"
                },
                "manifest_ref": {
                    "$ref": "#/$defs/safe_path"
                },
                "admission_authority": {
                    "$ref": "#/$defs/safe_path"
                },
                "framework_owner": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "provider": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "provider_revision": {
                    "type": "string",
                    "format": "docara-immutable-revision"
                },
                "upstream_revision": {
                    "type": "string",
                    "format": "docara-immutable-revision"
                },
                "manifest_sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                },
                "runtime_pair": {
                    "type": "string",
                    "pattern": "^[a-z0-9][a-z0-9._-]+$"
                }
            },
            "additionalProperties": false
        },
        "consumer_policy": {
            "type": "object",
            "required": ["can_admit", "managed_properties", "forbidden_inputs", "omitted_assets", "excluded_states"],
            "properties": {
                "can_admit": {
                    "type": "boolean",
                    "const": false
                },
                "managed_properties": {
                    "$ref": "#/$defs/string_list"
                },
                "forbidden_inputs": {
                    "$ref": "#/$defs/string_list"
                },
                "omitted_assets": {
                    "$ref": "#/$defs/string_list"
                },
                "excluded_states": {
                    "$ref": "#/$defs/string_list"
                }
            },
            "additionalProperties": false
        },
        "gap": {
            "type": "object",
            "required": ["owner", "reason", "fallback", "admission_condition"],
            "properties": {
                "owner": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "reason": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "fallback": {
                    "$ref": "#/$defs/non_empty_string"
                },
                "admission_condition": {
                    "$ref": "#/$defs/non_empty_string"
                }
            },
            "additionalProperties": false
        }
    }
}
