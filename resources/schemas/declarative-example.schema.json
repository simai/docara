{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.simai.io/docara/declarative-example/v1",
  "title": "Docara declarative demonstrator example",
  "type": "object",
  "required": ["schema", "id", "title", "description", "category", "order", "result_page", "preview", "sources"],
  "properties": {
    "schema": {"type": "string", "const": "docara.declarative_example.v1"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "category": {"type": "string", "enum": ["regions", "inheritance", "presets", "smart"]},
    "order": {"type": "integer", "minimum": 0},
    "result_page": {"type": "string", "pattern": "^content/[a-z0-9._/-]+\\.md$"},
    "preview": {"type": "string", "enum": ["compact", "normal", "tall"]},
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["label", "path", "language"],
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^(?:docara\\.json|(?:content|examples)/[a-z0-9._/-]+\\.(?:md|json))$"},
          "language": {"type": "string", "enum": ["markdown", "json"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
