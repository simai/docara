{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.simai.io/docara/declarative-section/v1",
  "type": "object",
  "required": ["schema", "key", "type", "allowed_regions", "allowed_blocks"],
  "properties": {
    "schema": {"type": "string", "const": "docara.section.v1"},
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
    "type": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
    "allowed_regions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
      "uniqueItems": true
    },
    "allowed_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
