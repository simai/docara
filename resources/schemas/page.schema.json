{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/page/v1",
    "title": "Docara portable page sidecar",
    "type": "object",
    "required": ["schema"],
    "properties": {
        "schema": {
            "type": "string",
            "const": "docara.page.v1"
        },
        "version": {
            "type": "integer",
            "const": 1
        },
        "preset": {
            "type": "string",
            "enum": ["docs", "landing"]
        },
        "title": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string"
        },
        "slug": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9._-]*[a-z0-9_-])?(?:/[a-z0-9](?:[a-z0-9._-]*[a-z0-9_-])?)*$"
        },
        "locale": {
            "type": "string",
            "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$"
        },
        "theme": {
            "type": "string",
            "minLength": 1
        },
        "layout": {
            "type": "object"
        },
        "settings": {
            "type": "object"
        },
        "navigation": {
            "type": "object"
        },
        "variables": {
            "type": "object"
        },
        "components": {
            "type": "array",
            "items": {
                "$ref": "component-call.schema.json"
            }
        }
    },
    "additionalProperties": false
}
