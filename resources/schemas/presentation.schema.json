{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/presentation/v1",
    "title": "Docara portable presentation fragments",
    "$defs": {
        "branding": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "label": {
                    "type": "string",
                    "minLength": 1
                },
                "logo": {
                    "type": "string",
                    "format": "docara-relative-path"
                },
                "logo_dark": {
                    "type": "string",
                    "format": "docara-relative-path"
                },
                "favicon": {
                    "type": "string",
                    "format": "docara-relative-path"
                }
            },
            "additionalProperties": false
        },
        "layout": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "key": {
                    "type": "string",
                    "enum": ["docara.docs"]
                },
                "max_width": {
                    "type": "string",
                    "enum": ["compact", "normal", "wide", "full"]
                },
                "regions": {
                    "$ref": "#/$defs/regions"
                }
            },
            "additionalProperties": false
        },
        "regions": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "header": {
                    "$ref": "#/$defs/region"
                },
                "sidebar": {
                    "$ref": "#/$defs/region"
                },
                "main": {
                    "$ref": "#/$defs/region"
                },
                "outline": {
                    "$ref": "#/$defs/region"
                },
                "footer": {
                    "$ref": "#/$defs/region"
                }
            },
            "additionalProperties": false
        },
        "region": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "enabled": {
                    "type": "boolean"
                },
                "sections": {
                    "type": "array",
                    "maxItems": 8,
                    "items": {
                        "$ref": "#/$defs/region_section"
                    }
                }
            },
            "additionalProperties": false
        },
        "region_section": {
            "type": "object",
            "required": ["id", "section"],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_.-]+$"
                },
                "section": {
                    "type": "string",
                    "enum": ["docara.header", "docara.navigation", "docara.outline", "docara.shell"]
                },
                "blocks": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 12,
                    "items": {
                        "$ref": "#/$defs/region_block"
                    }
                },
                "utilities": {
                    "type": "array",
                    "maxItems": 16,
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_:/.-]*$"},
                    "uniqueItems": true
                }
            },
            "additionalProperties": false
        },
        "region_block": {
            "oneOf": [
                {
                    "type": "object",
                    "required": ["id", "block", "slot", "element"],
                    "properties": {
                        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
                        "block": {"const": "shell.element"},
                        "slot": {"const": "content"},
                        "element": {
                            "type": "object",
                            "required": ["tag", "text"],
                            "properties": {
                                "tag": {"type": "string", "enum": ["div", "p", "span", "a"]},
                                "text": {"type": "string", "minLength": 1, "maxLength": 500},
                                "href": {"type": "string", "pattern": "^(?:/|#)[^\\u0000-\\u0020\\\"'<>\\\\]+$"},
                                "aria_label": {"type": "string", "minLength": 1, "maxLength": 160},
                                "utilities": {
                                    "type": "array",
                                    "maxItems": 16,
                                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_:/.-]*$"},
                                    "uniqueItems": true
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "required": ["id", "block", "slot", "smart", "props"],
                    "properties": {
                        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
                        "block": {"const": "shell.smart"},
                        "slot": {"const": "content"},
                        "smart": {"type": "string", "enum": ["ui.alert", "ui.button"]},
                        "view": {"type": "string", "const": "default"},
                        "props": {"type": "object", "maxProperties": 32}
                    },
                    "additionalProperties": false
                }
            ]
        },
        "settings": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "theme": {
                    "type": "string",
                    "enum": ["system", "light", "dark"]
                }
            },
            "additionalProperties": false
        },
        "navigation": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "hidden": {
                    "type": "boolean"
                },
                "order": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 2147483647
                }
            },
            "additionalProperties": false
        },
        "search": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "enabled": {
                    "type": "boolean"
                },
                "indexed": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "reading": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "breadcrumbs": {
                    "type": "boolean"
                },
                "toc": {
                    "type": "boolean"
                },
                "mobile_toc": {
                    "type": "string",
                    "enum": ["auto", "always", "never"]
                },
                "toc_depth": {
                    "type": "integer",
                    "minimum": 2,
                    "maximum": 6
                },
                "previous_next": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        }
    }
}
