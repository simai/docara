{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/presentation/v1",
    "title": "Docara portable presentation fragments",
    "$defs": {
        "branding": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "label": {
                    "type": "string",
                    "minLength": 1
                },
                "logo": {
                    "type": "string",
                    "format": "docara-relative-path"
                },
                "logo_dark": {
                    "type": "string",
                    "format": "docara-relative-path"
                },
                "favicon": {
                    "type": "string",
                    "format": "docara-relative-path"
                }
            },
            "additionalProperties": false
        },
        "layout": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "max_width": {
                    "type": "string",
                    "enum": ["compact", "normal", "wide", "full"]
                }
            },
            "additionalProperties": false
        },
        "settings": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "theme": {
                    "type": "string",
                    "enum": ["system", "light", "dark"]
                }
            },
            "additionalProperties": false
        },
        "navigation": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "hidden": {
                    "type": "boolean"
                },
                "order": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 2147483647
                }
            },
            "additionalProperties": false
        },
        "search": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$reset": {
                    "const": true
                },
                "enabled": {
                    "type": "boolean"
                },
                "indexed": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        }
    }
}
