{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/search-index/v1",
    "title": "Docara deterministic local search index",
    "type": "object",
    "required": ["schema", "version", "algorithm", "content_sha256", "documents"],
    "properties": {
        "schema": {
            "type": "string",
            "const": "docara.search_index.v1"
        },
        "version": {
            "type": "integer",
            "const": 1
        },
        "algorithm": {
            "type": "string",
            "const": "docara-prefix-v1"
        },
        "content_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
        },
        "documents": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["id", "url", "locale", "title", "description", "trail", "headings", "text"],
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^[a-f0-9]{64}$"
                    },
                    "url": {
                        "type": "string",
                        "pattern": "^/(?:(?!\\.{1,2}/)[A-Za-z0-9._~-]+/)*$"
                    },
                    "locale": {
                        "type": "string",
                        "format": "docara-bcp47"
                    },
                    "title": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": "string"
                    },
                    "trail": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "headings": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["level", "text"],
                            "properties": {
                                "level": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "maximum": 6
                                },
                                "text": {
                                    "type": "string",
                                    "minLength": 1
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "text": {
                        "type": "string"
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}
