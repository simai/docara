{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/section/v1",
    "title": "Docara portable section",
    "type": "object",
    "required": ["schema"],
    "properties": {
        "schema": {
            "type": "string",
            "const": "docara.section.v1"
        },
        "version": {
            "type": "integer",
            "const": 1
        },
        "preset": {
            "type": "string",
            "enum": ["docs", "landing"]
        },
        "title": {
            "type": "string",
            "minLength": 1
        },
        "locale": {
            "type": "string",
            "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$"
        },
        "branding": {
            "$ref": "presentation.schema.json#/$defs/branding"
        },
        "layout": {
            "$ref": "presentation.schema.json#/$defs/layout"
        },
        "settings": {
            "$ref": "presentation.schema.json#/$defs/settings"
        },
        "navigation": {
            "$ref": "presentation.schema.json#/$defs/navigation"
        },
        "search": {
            "$ref": "presentation.schema.json#/$defs/search"
        }
    },
    "additionalProperties": false
}
