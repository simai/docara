{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.simai.io/docara/typed-component-definition/v1",
    "title": "Docara typed component definition",
    "type": "object",
    "required": [
        "id",
        "name",
        "renderer",
        "family",
        "category",
        "title",
        "description",
        "lifecycle",
        "authoring",
        "states",
        "limitations",
        "verification",
        "docs_ref",
        "example_ref",
        "provenance"
    ],
    "properties": {
        "id": {
            "$ref": "component-catalog-entry.schema.json#/$defs/id"
        },
        "name": {
            "type": "string",
            "pattern": "^(?!ui)[a-z][a-z0-9_]*$"
        },
        "renderer": {
            "type": "string",
            "pattern": "^docara\\.[a-z][a-z0-9_]*\\.v[1-9][0-9]*$"
        },
        "family": {
            "type": "string",
            "const": "docara_typed"
        },
        "category": {
            "$ref": "component-catalog-entry.schema.json#/$defs/non_empty_string"
        },
        "title": {
            "$ref": "component-catalog-entry.schema.json#/$defs/non_empty_string"
        },
        "description": {
            "$ref": "component-catalog-entry.schema.json#/$defs/non_empty_string"
        },
        "lifecycle": {
            "type": "string",
            "const": "supported"
        },
        "authoring": {
            "$ref": "component-catalog-entry.schema.json#/$defs/authoring"
        },
        "states": {
            "$ref": "component-catalog-entry.schema.json#/$defs/string_list"
        },
        "limitations": {
            "$ref": "component-catalog-entry.schema.json#/$defs/string_list"
        },
        "verification": {
            "$ref": "component-catalog-entry.schema.json#/$defs/verification"
        },
        "docs_ref": {
            "$ref": "component-catalog-entry.schema.json#/$defs/safe_path"
        },
        "example_ref": {
            "$ref": "component-catalog-entry.schema.json#/$defs/safe_path"
        },
        "provenance": {
            "$ref": "component-catalog-entry.schema.json#/$defs/provenance"
        }
    },
    "additionalProperties": false
}
